// collect 래핑: userId/userName/staff 자동 기록
var _origCollect = collect;
collect = function(){
  var data = _origCollect();
  var s = getSession();
  if(s){
    data.basic.userId = s.id;
    data.basic.userName = s.name;
    data.basic.staff = s.name;
  }
  return data;
};

// saveData 래핑: 사용자별 키에 저장 + 관리자 rfSaves 병합
var _origSaveData = saveData;
saveData = function(){
  const data = collect();
  const title = (gv('address')||'주소미입력') + ' | ' + (gv('accDate')||'날짜미입력');
  if(!cid){ cid = 'C'+Date.now(); data.caseId = cid; }
  const saves = getSaves();
  saves[cid] = Object.assign({}, data, {title: title, caseId: cid});
  _saveAll(saves);  // 사용자 키 + 관리자 rfSaves 동시 저장
  document.getElementById('cidDisplay').textContent = cid;
  showToast('💾 저장 완료!');
  if(typeof renderMyContent==='function') try{ renderMyContent(); }catch(e){}
};

// renderSL 래핑: 불러오기 모달도 내 사건만 표시
var _origRenderSL = renderSL;
renderSL = function(){
  var saves = getSaves();
  var keys = Object.keys(saves).sort(function(a,b){ return saves[b].savedAt>saves[a].savedAt?1:-1; });
  var el2 = document.getElementById('saveList');
  el2.innerHTML = keys.length ? keys.map(function(k){
    var s = saves[k];
    var dt = s.savedAt ? new Date(s.savedAt).toLocaleString('ko-KR') : '';
    return '<div class="si" onclick="loadCase(\''+k+'\')"><div class="sii"><div class="sit">'+(s.title||k)+'</div><div class="sim">'+k+' | '+dt+'</div></div>'
      +'<button class="sid" onclick="delCase(\''+k+'\',event)">🗑️</button></div>';
  }).join('') : '<div class="se">저장된 사건이 없습니다</div>';
};

// delCase 래핑: 사용자 키에서도 삭제
var _origDelCase = delCase;
delCase = function(id, e){
  e.stopPropagation();
  customConfirm('이 사건을 삭제할까요?', function(){
    var saves = getSaves();
    delete saves[id];
    _saveAll(saves);
    renderSL();
    showToast('🗑️ 삭제 완료');
  });
};

