<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no">
<meta name="theme-color" content="#1a2b4a">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-title" content="Refound 적산">
<title>손해사정 적산 | Refound</title>
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
body{font-family:-apple-system,'Malgun Gothic','Apple SD Gothic Neo',sans-serif;background:#f0ede8;color:#1a1714;font-size:14px;padding-bottom:80px}
input,select,textarea,button{font-family:inherit}
:root{--navy:#1a2b4a;--blue:#2c3e6b;--blueL:#eef0f6;--red:#c0392b;--redL:#fdf0ef;--gold:#b8963e;--goldL:#faf6ec;--green:#1e6b4a;--greenL:#edf5f1;--purple:#6c3483;--purpleL:#f5eef8;--rule:#e0dbd4;--ink2:#5a5550;--ink3:#9a948e;--bg2:#faf9f7}
.app-header{background:var(--navy);color:#fff;padding:13px 16px 11px;display:flex;align-items:center;justify-content:space-between}
.app-header img{height:26px;object-fit:contain}
.app-header .ht{font-size:10px;color:rgba(255,255,255,.5);text-align:right;line-height:1.5}
.save-bar{background:#1e3355;padding:6px 14px;display:flex;align-items:center;justify-content:space-between;gap:8px}
.save-bar .cid{color:#7dd3fc;font-weight:700;font-size:11px}
.save-bar .cid-label{color:rgba(255,255,255,.5);font-size:10px}
.hbtn{padding:5px 11px;border-radius:6px;border:none;cursor:pointer;font-size:11px;font-weight:700}
.hbtn-s{background:#22c55e;color:#fff}
.hbtn-l{background:rgba(255,255,255,.15);color:#fff}
.hbtn-n{background:var(--red);color:#fff}
.tabs{display:flex;background:#fff;border-bottom:2px solid var(--rule);position:sticky;top:0;z-index:50;box-shadow:0 2px 8px rgba(0,0,0,.06);overflow-x:auto}
.tabs::-webkit-scrollbar{display:none}
.tb{flex:none;min-width:58px;padding:8px 4px;border:none;background:transparent;cursor:pointer;font-size:10px;font-weight:500;color:var(--ink3);border-bottom:3px solid transparent;margin-bottom:-2px;display:flex;flex-direction:column;align-items:center;gap:2px}
.tb .ti{font-size:15px}
.tb.on{color:var(--blue);font-weight:700;border-bottom-color:var(--blue)}
.tc{display:none;padding:14px}
.tc.on{display:block}
.card{background:#fff;border-radius:12px;box-shadow:0 2px 12px rgba(0,0,0,.06);margin-bottom:12px;overflow:hidden}
.ch{display:flex;align-items:center;gap:10px;padding:12px 15px;border-bottom:1px solid var(--rule)}
.ch b{font-size:14px;flex:1}
.cb{padding:13px 15px}
.ib{width:30px;height:30px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0}
.r2{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px}
.r3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:10px}
.r1{margin-bottom:10px}
.fg label{display:block;font-size:11px;font-weight:600;color:var(--ink2);margin-bottom:4px}
.fg input,.fg select,.fg textarea{width:100%;padding:9px 11px;border:1.5px solid var(--rule);border-radius:7px;font-size:13px;background:var(--bg2);outline:none;transition:border-color .15s}
.fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(--blue);background:#fff}
.fg textarea{resize:vertical;min-height:70px}
.fg input[readonly]{background:#eee;color:var(--ink2)}
.nt{border-radius:8px;padding:10px 14px;font-size:11px;line-height:1.7;margin-bottom:14px}
.nt-gold{background:var(--goldL);border:1px solid var(--gold);color:#7a6020}
.nt-blue{background:var(--blueL);border:1px solid var(--blue);color:var(--blue)}
.nt-purple{background:var(--purpleL);border:1px solid var(--purple);color:var(--purple)}
.depr-box{background:var(--goldL);border:1px solid var(--gold);border-radius:8px;padding:12px 14px}
.depr-box h4{font-size:13px;font-weight:700;color:var(--gold);margin-bottom:8px}
.dr{display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px}
.dr.tr{border-top:1px solid var(--gold);padding-top:6px;margin-top:4px;font-weight:700}
.tw-wrap{display:flex;align-items:center;gap:10px;margin-bottom:12px}
.tw-wrap label{font-size:13px;font-weight:600;color:var(--ink2)}
.tgl{position:relative;width:46px;height:26px;flex-shrink:0}
.tgl input{opacity:0;width:0;height:0}
.tgl-s{position:absolute;inset:0;background:#ccc;border-radius:26px;cursor:pointer;transition:.2s}
.tgl-s:before{content:'';position:absolute;width:20px;height:20px;left:3px;top:3px;background:#fff;border-radius:50%;transition:.2s}
.tgl input:checked+.tgl-s{background:var(--blue)}
.tgl input:checked+.tgl-s:before{transform:translateX(20px)}
.adj-card{background:var(--purpleL);border:1.5px solid #d2b4de;border-radius:10px;padding:13px;margin-bottom:10px;position:relative}
.pcard{background:var(--bg2);border:1.5px solid var(--rule);border-radius:10px;padding:13px;margin-bottom:10px;position:relative}
.del-x{position:absolute;top:10px;right:10px;background:none;border:none;cursor:pointer;color:var(--red);font-size:20px;line-height:1}
.add-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:6px}
.add-chip{padding:10px;background:var(--bg2);border:1.5px dashed var(--rule);border-radius:9px;cursor:pointer;font-size:12px;font-weight:600;color:var(--ink2);text-align:center;transition:all .15s}
.add-chip:active{background:var(--blueL);border-color:var(--blue)}
.ws{background:#fff;border-radius:12px;box-shadow:0 2px 12px rgba(0,0,0,.06);margin-bottom:12px;overflow:hidden}
.wsh{display:flex;align-items:center;gap:10px;padding:12px 15px;border-bottom:1px solid var(--rule)}
.wsh-title{flex:1;font-size:14px;font-weight:700}
.wsd-btn{background:none;border:none;cursor:pointer;color:var(--red);font-size:16px;padding:2px 6px;border-radius:6px}
.wsb{padding:13px 15px}
.add-sec-btn{width:100%;padding:11px;border-radius:9px;border:2px dashed var(--rule);background:transparent;cursor:pointer;font-size:13px;font-weight:600;color:var(--ink3);margin-bottom:10px;transition:all .15s}
.add-sec-btn:hover{border-color:var(--blue);color:var(--blue);background:var(--blueL)}
.tw{overflow-x:auto;margin-bottom:8px}
.wt{width:100%;border-collapse:collapse;font-size:12px;min-width:510px}
.wt th{background:var(--blue);color:#fff;padding:7px 4px;font-weight:600;font-size:11px;white-space:nowrap;text-align:center}
.wt th:first-child{text-align:left;padding-left:8px}
.wt td{padding:5px 3px;border-bottom:1px solid var(--rule);vertical-align:middle}
.wt tr:last-child td{border-bottom:none}
.wt input,.wt select{width:100%;padding:5px 5px;border:1.5px solid var(--rule);border-radius:5px;font-size:12px;background:#fff;outline:none;text-align:right}
.wt input.tl,.wt select{text-align:left}
.wt .rt{text-align:right;font-weight:700;color:var(--blue);white-space:nowrap;font-size:11px}
.delbtn{background:none;border:none;cursor:pointer;color:var(--red);font-size:18px;padding:0 2px;line-height:1}
.arb{width:100%;padding:8px;border-radius:7px;cursor:pointer;font-size:12px;font-weight:600;margin-top:5px}
.arb-p{background:var(--blueL);color:var(--blue);border:1.5px dashed rgba(44,62,107,.3)}
.arb-c{background:var(--bg2);color:var(--ink2);border:1.5px solid var(--rule)}
.sg{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px}
.sb{border-radius:10px;padding:13px;text-align:center}
.sb .sl{font-size:11px;font-weight:600;margin-bottom:5px;opacity:.8}
.sb .sv{font-size:16px;font-weight:800}
.st{grid-column:1/-1;background:var(--navy);padding:18px}
.st .sl{color:rgba(255,255,255,.7)}
.st .sv{color:#fff;font-size:24px}
.bt{width:100%;border-collapse:collapse;font-size:13px}
.bt td{padding:8px 6px;border-bottom:1px solid var(--rule)}
.bt .sub td{color:var(--ink3);font-size:12px}
.bt .subtotal td{background:var(--bg2);font-weight:700}
.bt .grand td{background:var(--navy);color:#fff;font-weight:700}
.bt td:last-child{text-align:right}
.rlb{background:var(--navy);border-radius:10px;padding:14px 18px;margin-bottom:14px;display:flex;align-items:center;justify-content:space-between}
.rlb img{height:26px;object-fit:contain}
.rlb .rt2{text-align:right;color:rgba(255,255,255,.65);font-size:10px;line-height:1.8}
.rlb .rt2 b{color:#fff;font-size:13px}
.sec-t{font-weight:700;font-size:13px;padding:6px 0 8px;border-bottom:2px solid var(--navy);margin-bottom:10px;margin-top:14px;display:flex;align-items:center;gap:8px}
.sec-t:first-child{margin-top:0}
.stb{width:4px;height:14px;border-radius:2px;display:inline-block}
.ig{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-bottom:14px}
.ii{background:#fff;border:1px solid var(--rule);border-radius:7px;padding:9px 12px}
.ii .ik{font-size:10px;color:var(--ink3);font-weight:600;margin-bottom:2px}
.ii .iv{font-size:12px;font-weight:600;word-break:break-all}
.rt{width:100%;border-collapse:collapse;font-size:12px;margin-bottom:12px}
.rt th{background:var(--navy);color:#fff;padding:7px 8px;font-size:11px;text-align:left;font-weight:600}
.rt td{padding:7px 8px;border-bottom:1px solid var(--rule)}
.rt tr:nth-child(even) td{background:var(--bg2)}
.rtag{padding:2px 7px;border-radius:20px;font-size:10px;font-weight:700;display:inline-block}
.rfooter{background:var(--navy);border-radius:10px;padding:13px 18px;margin-top:14px;display:flex;align-items:center;gap:14px}
.rfooter img{height:20px;object-fit:contain;flex-shrink:0}
.rfooter .fi{font-size:10px;color:rgba(255,255,255,.6);line-height:1.8}
.rfooter .fi b{color:#fff}
.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:300;display:none;align-items:flex-end}
.modal-bg.on{display:flex}
.msheet{background:#fff;width:100%;border-radius:20px 20px 0 0;max-height:86vh;overflow-y:auto;padding:18px}
.mhandle{width:40px;height:4px;background:var(--rule);border-radius:2px;margin:0 auto 14px}
.mtitle{font-weight:700;font-size:16px;margin-bottom:14px}
.pcat{font-size:11px;font-weight:700;color:var(--ink3);letter-spacing:1px;padding-bottom:4px;border-bottom:1px solid var(--rule);margin-bottom:8px;margin-top:14px}
.pgrid{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-bottom:4px}
.pitem{padding:9px 10px;border:1.5px solid var(--rule);border-radius:8px;cursor:pointer;background:var(--bg2);-webkit-user-select:none}
.pitem:active{background:var(--blueL);border-color:var(--blue)}
.pitem .pn{font-size:12px;font-weight:600;margin-bottom:2px}
.pitem .pp{font-size:11px;color:var(--red);font-weight:700}
.pitem .ps{font-size:10px;color:var(--ink3)}
.mc{width:100%;padding:13px;background:var(--bg2);border:none;border-radius:9px;font-size:13px;font-weight:600;cursor:pointer;color:var(--ink2);margin-top:10px}
.si{display:flex;align-items:center;gap:10px;padding:12px;border:1.5px solid var(--rule);border-radius:10px;margin-bottom:8px;background:var(--bg2)}
.si:active{background:var(--blueL)}
.si .sii{flex:1}
.si .sit{font-weight:700;font-size:13px;margin-bottom:2px}
.si .sim{font-size:10px;color:var(--ink3)}
.si .sid{background:none;border:none;cursor:pointer;color:var(--red);font-size:16px;padding:4px}
.se{text-align:center;color:var(--ink3);font-size:13px;padding:30px 0}
.abar{position:fixed;bottom:0;left:0;right:0;background:#fff;border-top:1px solid var(--rule);padding:10px 14px;display:flex;gap:8px;box-shadow:0 -4px 20px rgba(0,0,0,.08);z-index:100}
.abtn{flex:1;padding:12px 4px;border-radius:9px;font-size:12px;font-weight:700;cursor:pointer;border:none;text-align:center}
.abtn-s{background:#22c55e;color:#fff}
.abtn-c{background:var(--blueL);color:var(--blue);border:1.5px solid rgba(44,62,107,.2)!important}
.abtn-r{flex:2;background:var(--navy);color:#fff}
.toast{position:fixed;bottom:90px;left:50%;transform:translateX(-50%);background:#1a1714;color:#fff;padding:10px 20px;border-radius:20px;font-size:13px;font-weight:600;z-index:500;opacity:0;transition:opacity .3s;pointer-events:none;white-space:nowrap}
.toast.show{opacity:1}

/* ── 배당 탭 ── */
.assign-btn{padding:18px 8px;border-radius:12px;border:2px solid var(--rule);background:#fff;cursor:pointer;font-size:15px;font-weight:700;text-align:center;color:var(--ink2);transition:all .15s;-webkit-user-select:none;user-select:none}
.assign-btn:active{opacity:.8}
.assign-btn.selected{background:var(--navy);color:#fff;border-color:var(--navy);box-shadow:0 4px 12px rgba(26,43,74,.3)}

/* ── 인라인 배당 버튼 ── */
.assign-inline-btn{padding:12px 4px;border-radius:10px;border:2px solid var(--rule);background:#fff;cursor:pointer;font-size:13px;font-weight:700;text-align:center;color:var(--ink2);transition:all .15s;-webkit-user-select:none;user-select:none}
.assign-inline-btn:active{opacity:.8}
.assign-inline-btn.selected{background:var(--navy);color:#fff;border-color:var(--navy)}

/* ── 알림 팝업 ── */
.notif-popup{position:fixed;top:0;left:0;right:0;z-index:8000;background:var(--navy);color:#fff;padding:16px 18px;display:flex;align-items:flex-start;gap:14px;box-shadow:0 4px 20px rgba(0,0,0,.3);transform:translateY(-110%);transition:transform .4s cubic-bezier(.25,.8,.25,1)}
.notif-popup.show{transform:translateY(0)}
.notif-icon{font-size:28px;flex-shrink:0;margin-top:2px}
.notif-body{flex:1}
.notif-title{font-weight:800;font-size:14px;margin-bottom:3px}
.notif-msg{font-size:12px;color:rgba(255,255,255,.75);line-height:1.5}
.notif-close{background:none;border:none;color:rgba(255,255,255,.5);font-size:22px;cursor:pointer;padding:0;line-height:1;flex-shrink:0}
.notif-badge{position:fixed;top:70px;right:14px;background:var(--red);color:#fff;border-radius:50%;width:22px;height:22px;font-size:11px;font-weight:800;display:flex;align-items:center;justify-content:center;z-index:7000;display:none}

/* ── 로그인 화면 ── */
#loginScreen{position:fixed;inset:0;background:var(--navy);z-index:9999;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:28px}
#loginScreen.hidden{display:none}
.login-box{width:100%;max-width:340px}
.login-logo{font-size:28px;font-weight:900;color:#fff;letter-spacing:-1px;text-align:center}
.login-sub{font-size:11px;color:rgba(255,255,255,.35);letter-spacing:3px;text-align:center;margin-top:4px;margin-bottom:32px}
.login-field{margin-bottom:14px}
.login-field label{display:block;font-size:11px;font-weight:700;color:rgba(255,255,255,.4);margin-bottom:6px}
.login-field input{width:100%;padding:14px 16px;background:rgba(255,255,255,.1);border:1.5px solid rgba(255,255,255,.15);border-radius:10px;color:#fff;font-size:15px;outline:none;-webkit-appearance:none}
.login-field input:focus{border-color:rgba(255,255,255,.5);background:rgba(255,255,255,.13)}
.login-field input::placeholder{color:rgba(255,255,255,.25)}
.login-err{color:#fca5a5;font-size:12px;font-weight:600;text-align:center;min-height:18px;margin:8px 0}
.login-btn{width:100%;padding:15px;border-radius:10px;border:none;background:#fff;color:var(--navy);font-size:15px;font-weight:800;cursor:pointer;margin-top:4px;-webkit-tap-highlight-color:transparent}
.login-btn:active{opacity:.85}
.login-footer{text-align:center;margin-top:28px;font-size:11px;color:rgba(255,255,255,.22);line-height:1.8}

/* ── 직원 바 ── */
.staff-bar{background:#0f1f38;padding:6px 14px;display:flex;align-items:center;justify-content:space-between;gap:8px}
.staff-bar .sname{color:#fbbf24;font-weight:700;font-size:12px;display:flex;align-items:center;gap:5px}
.staff-bar .sbadge{background:rgba(251,191,36,.15);border:1px solid rgba(251,191,36,.4);border-radius:20px;padding:2px 9px;font-size:10px;color:rgba(255,255,255,.5)}
.staff-chg-btn{background:rgba(255,255,255,.1);border:none;color:#fff;font-size:10px;font-weight:700;padding:4px 10px;border-radius:6px;cursor:pointer}

/* ── 내 사건 탭 ── */
.my-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:12px}
.my-sbox{border-radius:10px;padding:11px;text-align:center}
.my-sbox .msl{font-size:10px;font-weight:600;margin-bottom:3px;opacity:.8}
.my-sbox .msv{font-size:18px;font-weight:800}
.my-case-card{background:#fff;border-radius:10px;box-shadow:0 1px 6px rgba(0,0,0,.06);padding:12px;border-left:4px solid var(--rule);margin-bottom:8px;cursor:pointer;-webkit-user-select:none;user-select:none}
.my-case-card:active{background:var(--bg2)}
.mcr1{display:flex;align-items:flex-start;justify-content:space-between;gap:8px;margin-bottom:4px}
.mc-title{font-weight:700;font-size:13px;flex:1;line-height:1.4}
.mc-stag{padding:2px 8px;border-radius:20px;font-size:10px;font-weight:700;white-space:nowrap;flex-shrink:0}
.mcr2{font-size:11px;color:var(--ink3);line-height:1.8}
.mcr2 span{margin-right:8px}
.my-chips{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:12px}
.my-chip{padding:4px 10px;border-radius:20px;font-size:11px;font-weight:600;border:1.5px solid var(--rule);background:#fff;cursor:pointer;color:var(--ink2);white-space:nowrap;-webkit-user-select:none;user-select:none;transition:all .12s}
.my-chip.on{background:var(--blue);color:#fff;border-color:var(--blue)}
.my-empty{text-align:center;padding:36px 20px;color:var(--ink3);font-size:13px}
.my-empty .ei{font-size:36px;margin-bottom:10px}

/* ── 상태 모달 ── */
.mst-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-bottom:12px}
.mst-btn{padding:9px 4px;border-radius:8px;border:1.5px solid var(--rule);background:#fff;cursor:pointer;font-size:11px;font-weight:600;text-align:center;color:var(--ink2);-webkit-user-select:none;user-select:none}
.mst-btn.active{border-width:2px}
.hist-item{padding:6px 0;border-bottom:1px solid var(--rule);font-size:11px}
.hist-item:last-child{border-bottom:none}

/* ── 직원 선택 모달 ── */
.staff-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:12px}
.staff-btn{padding:14px 8px;border-radius:10px;border:1.5px solid var(--rule);background:var(--bg2);cursor:pointer;font-size:13px;font-weight:700;text-align:center;color:var(--ink2);-webkit-user-select:none;user-select:none;transition:all .15s}
.staff-btn.me{background:var(--navy);color:#fff;border-color:var(--navy)}
.staff-btn:active{opacity:.8}
</style>
</head>
<body>

<!-- ════ 로그인 화면 ════ -->
<div id="loginScreen">
  <div class="login-box">
    <div class="login-logo">Refound</div>
    <div class="login-sub">손해사정 적산 시스템</div>
    <div class="login-field">
      <label>아이디</label>
      <input type="text" id="loginId" placeholder="아이디 입력" autocapitalize="none" autocomplete="off">
    </div>
    <div class="login-field">
      <label>비밀번호</label>
      <input type="password" id="loginPw" placeholder="비밀번호 입력" onkeydown="if(event.key==='Enter')doLogin()">
    </div>
    <div class="login-err" id="loginErr"></div>
    <button class="login-btn" onclick="doLogin()">로그인</button>
    <div class="login-footer">Refound Co., Ltd. | 경기도 안양시<br>아이디·비밀번호 문의: 관리자</div>
  </div>
</div>

<!-- ════ 앱 본체 ════ -->
<!-- 알림 팝업 -->
<div class="notif-popup" id="notifPopup">
  <div class="notif-icon">🔔</div>
  <div class="notif-body">
    <div class="notif-title" id="notifTitle">새 사건 배당</div>
    <div class="notif-msg" id="notifMsg">-</div>
  </div>
  <button class="notif-close" onclick="closeNotifPopup()">×</button>
</div>
