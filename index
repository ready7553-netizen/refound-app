  const tr=document.createElement('tr');tr.id='row-'+rid;
  tr.innerHTML=`
    <td><input class="tl" type="text" value="${p.name||''}" placeholder="항목명" oninput="calcAll()"></td>
    <td><input class="tl" type="text" value="${p.spec||''}" placeholder="규격" oninput="calcAll()"></td>
    <td><select oninput="calcAll()">${uo}</select></td>
