function getAdminData(){ try{ return JSON.parse(localStorage.getItem(ADMIN_KEY))||{}; }catch(e){ return{}; } }
function setAdminData(d){ localStorage.setItem(ADMIN_KEY, JSON.stringify(d)); }
function myGetStatus(c){ var adm=getAdminData(); return (adm[c.caseId]&&adm[c.caseId].status)||(c.basic&&c.basic.status)||'접수'; }
function myGetInsurer(c){ var b=c.basic||{}; return b.insurerSel==='직접입력'?(b.insurerCustom||'-'):(b.insurerSel||'-'); }
function myCalcGrand(c){
  if(!c||!c.wss) return 0;
  var direct=0;
  (c.wss||[]).forEach(function(s){ (s.rows||[]).forEach(function(r){ var q=parseFloat(r.qty)||0; direct+=((parseFloat(r.mat)||0)+(parseFloat(r.labor)||0)+(parseFloat(r.exp)||0))*q; }); });
  var ind=c.ind||{}, ovh=(parseFloat(ind.ovhRate)||6)/100, pft=(parseFloat(ind.pftRate)||10)/100, vat=(parseFloat(ind.vatRate)||10)/100;
  var sub=(direct*(1+ovh)*(1+pft))+(parseFloat(ind.survFee)||0)+(parseFloat(ind.rmvFee)||0);
  return Math.round(sub*(1+vat));
}
function myFmt(n){ n=Math.round(n||0); if(!n) return '-'; return n.toLocaleString('ko-KR')+'원'; }
function myDaysDiff(d){ if(!d) return 0; return Math.floor((new Date()-new Date(d))/(864e5)); }
function getCurrentStaff(){ var s=getSession(); return s?s.name:''; }

