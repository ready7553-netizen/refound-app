function getSession(){
  try{ return JSON.parse(localStorage.getItem(SESSION_KEY)); }catch(e){ return null; }
}
function setSession(user){
  localStorage.setItem(SESSION_KEY, JSON.stringify(user));
}
function clearSession(){
  localStorage.removeItem(SESSION_KEY);
}
function isAdmin(){
  var s = getSession();
  return !!(s && USERS[s.id] && USERS[s.id].isAdmin);
}

// 사용자별 저장 키
function getUserSK(){
  var s = getSession();
  if(!s) return 'rfSaves_guest';
  return isAdmin() ? 'rfSaves' : 'rfSaves_' + s.id;
}

// getSaves: 관리자는 모든 직원 데이터를 합산, 일반 직원은 본인 키만
function getSaves(){
  try{
    if(isAdmin()){
      // 마스터 rfSaves + 각 직원 키 모두 병합
      var merged = JSON.parse(localStorage.getItem('rfSaves'))||{};
      USER_IDS.forEach(function(uid){
        try{
          var udata = JSON.parse(localStorage.getItem('rfSaves_'+uid))||{};
          Object.assign(merged, udata);
        }catch(e){}
      });
      return merged;
    }
    return JSON.parse(localStorage.getItem(getUserSK()))||{};
  }catch(e){ return{}; }
}

function _saveAll(saves){
  if(isAdmin()){
    localStorage.setItem('rfSaves', JSON.stringify(saves));
    return;
  }
  // 로컬 저장
  localStorage.setItem(getUserSK(), JSON.stringify(saves));
  try{
    var master=JSON.parse(localStorage.getItem('rfSaves'))||{};
    var s=getSession();
    Object.keys(master).forEach(function(k){
      if(master[k].basic&&master[k].basic.userId===(s&&s.id)) delete master[k];
    });
    Object.assign(master,saves);
    localStorage.setItem('rfSaves',JSON.stringify(master));
  }catch(e){}
  // 서버에도 저장 (백그라운드)
  try{
    var adm=getAdminData();
    Object.values(saves).forEach(function(c){
      apiPost({action:'saveCase', data:Object.assign({},c,{adminData:adm[c.caseId]||{}}), isNewAssign:false});
    });
  }catch(e){}
}

