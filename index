// 저장
function collect(){
  const wss=[];
  document.querySelectorAll('.ws').forEach(sec=>{
    const rows=[];
    sec.querySelectorAll('tbody tr').forEach(tr=>{
      const ins=tr.querySelectorAll('input');const sel=tr.querySelector('select');
      if(ins.length<5)return;
      rows.push({name:ins[0].value,spec:ins[1].value,unit:sel?sel.value:'㎡',qty:ins[2].value,mat:ins[3].value,labor:ins[4].value,exp:ins[5]?ins[5].value:0});
    });
    wss.push({type:sec.dataset.type,rows});
  });
  const persons=[...document.querySelectorAll('.pcard')].map(c=>{const id=c.id.replace('pc-','');return{role:c.querySelector('select').value,name:gv('pn-'+id),tel:gv('pt-'+id),addr:gv('pa-'+id),note:gv('pno-'+id)};});
  const adjs=[...document.querySelectorAll('.adj-card')].map(c=>{const id=c.id.replace('aj-','');return{type:c.querySelector('select').value,name:gv('ajn-'+id),tel:gv('ajt-'+id),company:gv('ajc-'+id),regNo:gv('ajr-'+id),note:gv('ajno-'+id)};});
  return{savedAt:new Date().toISOString(),caseId:cid,
    basic:{acType:gv('acType'),buildUse:gv('buildUse'),struct:gv('struct'),useful:gv('useful'),insurerSel:gv('insurerSel'),insurerCustom:gv('insurerCustom'),policyNo:gv('policyNo'),claimNo:gv('claimNo'),insAdj:gv('insAdj'),address:gv('address'),accDate:gv('accDate'),survDate:gv('survDate'),buildYear:gv('buildYear'),totArea:gv('totArea'),dmgArea:gv('dmgArea'),minRes:gv('minRes')},
    ind:{ovhRate:gv('ovhRate'),pftRate:gv('pftRate'),vatRate:gv('vatRate'),survFee:gv('survFee'),rmvFee:gv('rmvFee')},
    adjDelegated:document.getElementById('adjDelegated').checked,
    writer:{name:gv('wName'),regNo:gv('wRegNo'),company:gv('wCompany'),tel:gv('wTel'),repDate:gv('repDate'),note:gv('adjNote')},
    persons,adjs,wss};
}
