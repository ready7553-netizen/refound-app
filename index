function crt(inp){
  const tr=inp.closest('tr');if(!tr)return;
  const ns=tr.querySelectorAll('input[type=number]');if(ns.length<4)return;
  const q=parseFloat(ns[0].value)||0;
  const tot=(parseFloat(ns[1].value)||0)+(parseFloat(ns[2].value)||0)+(parseFloat(ns[3].value)||0);
  const r=tr.querySelector('[id^=rt-]');if(r)r.textContent=Math.round(q*tot).toLocaleString();
}

// 계산
function calcAll(){
  const secs=[...document.querySelectorAll('.ws')];
  let tMat=0,tLabor=0,tExp=0,direct=0;
  const secData=secs.map(sec=>{
    const type=sec.dataset.type;const meta=WM[type]||WM.other;
    let mat=0,labor=0,exp=0;
    sec.querySelectorAll('tbody tr').forEach(tr=>{
      const ns=tr.querySelectorAll('input[type=number]');if(ns.length<4)return;
      const q=parseFloat(ns[0].value)||0;
      mat+=(parseFloat(ns[1].value)||0)*q;labor+=(parseFloat(ns[2].value)||0)*q;exp+=(parseFloat(ns[3].value)||0)*q;
    });
    const tot=mat+labor+exp;tMat+=mat;tLabor+=labor;tExp+=exp;direct+=tot;
    return{type,label:meta.emoji+' '+meta.label,mat,labor,exp,total:tot};
  });
  const ovh=(parseFloat(gv('ovhRate'))||0)/100,pft=(parseFloat(gv('pftRate'))||0)/100,vat=(parseFloat(gv('vatRate'))||0)/100;
  const sf=parseFloat(gv('survFee'))||0,rf=parseFloat(gv('rmvFee'))||0;
  const overhead=direct*ovh,profit=(direct+overhead)*pft;
  const sub=direct+overhead+profit+sf+rf,vatA=sub*vat,grand=sub+vatA;
  const {el,ul,dr}=calcDepr();
  const dA=grand*dr,net=grand-dA;
  const cc={fire:{bg:'#fdf0ef',vc:'#c0392b'},water:{bg:'#eef0f6',vc:'#2c3e6b'},other:{bg:'#faf9f7',vc:'#5a5550'}};
  const sb=document.getElementById('sumBoxes');
  sb.innerHTML=secData.map(s=>{const c=cc[s.type]||cc.other;return`<div class="sb" style="background:${c.bg}"><div class="sl">${s.label}</div><div class="sv" style="color:${c.vc}">${fmt(s.total)}</div></div>`;}).join('')
    +`<div class="sb" style="background:#edf5f1"><div class="sl">🧱 재료비</div><div class="sv" style="color:#1e6b4a">${fmt(tMat)}</div></div>`
    +`<div class="sb" style="background:#faf6ec"><div class="sl">👷 노무비</div><div class="sv" style="color:#b8963e">${fmt(tLabor)}</div></div>`
    +`<div class="sb st"><div class="sl">■ 최종 손해인정액</div><div class="sv">${fmt(grand)}</div></div>`;
  const brs=[];
  secData.forEach(s=>{brs.push({l:s.label,v:s.total,c:''});brs.push({l:'　└ 재료비',v:s.mat,c:'sub'});brs.push({l:'　└ 노무비',v:s.labor,c:'sub'});brs.push({l:'　└ 경  비',v:s.exp,c:'sub'});});
  brs.push({l:'직접공사비 소계',v:direct,c:'subtotal'});
  brs.push({l:`일반관리비 (${(ovh*100).toFixed(1)}%)`,v:overhead,c:''});
  brs.push({l:`이윤 (${(pft*100).toFixed(1)}%)`,v:profit,c:''});
  brs.push({l:'손해조사비',v:sf,c:''});brs.push({l:'잔존물 제거비',v:rf,c:''});
  brs.push({l:`부가가치세 (${(vat*100).toFixed(1)}%)`,v:vatA,c:''});
  brs.push({l:'합  계',v:grand,c:'grand'});
  ['bdBody','rBdBody'].forEach(bid=>{const e=document.getElementById(bid);if(e)e.innerHTML=brs.map(r=>`<tr class="${r.c}"><td>${r.l}</td><td>${fmt(r.v)}</td></tr>`).join('');});
  const ys=el+'년 / '+ul+'년',rs=(dr*100).toFixed(1)+'%';
  [['da-',''],['rda-','']].forEach(([p])=>{
    const s=(s2,v)=>{const e=document.getElementById(p+s2);if(e)e.textContent=v;};
    s('g',fmt(grand));s('y',ys);s('r',rs);s('a',fmt(dA));s('n',fmt(net));
  });
  return{secData,grand,dA,net,direct,overhead,profit,vatA,sf,rf,ovh,pft,vat};
}

