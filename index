// 감가
function calcDepr(){
  const by=parseInt(gv('buildYear'))||0,ad=gv('accDate'),ul=parseInt(gv('useful'))||40,mr=(parseFloat(gv('minRes'))||0)/100;
  let el=0;if(by&&ad)el=Math.max(0,new Date(ad).getFullYear()-by);
  sv('elapsed',el?el+'년':'-');
  const th=Math.max(mr,1-el/ul),dr=(1-th);
  document.getElementById('dp-e').textContent=el+'년';
  document.getElementById('dp-u').textContent=ul+'년';
  document.getElementById('dp-t').textContent=(th*100).toFixed(1)+'%';
  document.getElementById('dp-d').textContent=(dr*100).toFixed(1)+'%';
  return{el,ul,dr};
}

