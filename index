function exportJSON(){
  var d=collect();var s=getSaves();
  var json=JSON.stringify({current:d,allSaves:s},null,2);
  // 아이폰/삼성 모두 호환되는 다운로드
  try {
    var b=new Blob([json],{type:'application/json'});
    var u=URL.createObjectURL(b);
    var a=document.createElement('a');a.href=u;a.download='refound_'+TODAY+'.json';
    document.body.appendChild(a);a.click();
    setTimeout(function(){document.body.removeChild(a);URL.revokeObjectURL(u);},300);
    showToast('📤 JSON 내보내기 완료');
  } catch(e) {
    // Blob 미지원 환경 (구형 브라우저) fallback
    var w=window.open('','_blank');
    if(w){w.document.write('<pre>'+json.replace(/</g,'&lt;')+'</pre>');w.document.title='refound_backup.json';}
    showToast('📤 새 탭에서 복사하세요');
  }
}
function importJSON(e){
  const f=e.target.files[0];if(!f)return;
  const r=new FileReader();r.onload=ev=>{try{const j=JSON.parse(ev.target.result);if(j.allSaves){const ex=getSaves();localStorage.setItem('rfSaves',JSON.stringify({...ex,...j.allSaves}));showToast('📥 가져오기 완료 '+Object.keys(j.allSaves).length+'건');renderSL();}if(j.current)restore(j.current);}catch{showToast('⚠️ 파일 형식 오류');}};r.readAsText(f);
}
function showToast(msg){var t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(function(){t.classList.remove('show');},2200);}

