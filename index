    // 마스터 rfSaves
    var master = {};
    try{ master = JSON.parse(localStorage.getItem('rfSaves'))||{}; }catch(e){}
    master[cid] = data;
    localStorage.setItem('rfSaves', JSON.stringify(master));

    // rfAdmin 초기 상태
