function doAssignAndSave(){
  if(!curAssigneeId){ showToast('⚠️ 담당자를 먼저 선택하세요'); return; }
  var addr = gv('address')||'';
  if(!addr){ showToast('⚠️ 소재지를 먼저 입력하세요'); showTab('info'); return; }

  customConfirm(curAssigneeName + '에게 배당하시겠습니까?', function(){
    var ins  = gv('insurerSel')==='직접입력'?(gv('insurerCustom')||''):gv('insurerSel')||'';
    var data = collect();
    var title = (addr||'주소미입력') + ' | ' + (gv('accDate')||'날짜미입력');
