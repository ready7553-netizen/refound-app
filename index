var NOTIF_KEY = 'rfNotifs';
var _notifBC  = null;   // BroadcastChannel
var _notifTimer = null;
var _lastNotifCheck = 0;
var _unreadCount = 0;

function initNotifSystem(){
  // Web Notifications 권한 요청
  if('Notification' in window && Notification.permission === 'default'){
    Notification.requestPermission();
  }
  // BroadcastChannel (같은 브라우저 내 탭 간 실시간 통신)
  if('BroadcastChannel' in window){
    _notifBC = new BroadcastChannel('rfNotifCh');
    _notifBC.onmessage = function(e){
      if(e.data && e.data.type === 'NEW_ASSIGN'){
        var s = getSession();
        if(s && e.data.targetUserId === s.id){
          showInAppNotif(e.data.addr, e.data.assignedByName||'관리자');
        }
      }
    };
  }
  // localStorage 폴링 (5초 간격) — 다른 기기·탭 대비
  _lastNotifCheck = Date.now();
  _notifTimer = setInterval(pollNotifs, 5000);
}

function pollNotifs(){
  var s = getSession(); if(!s||isAdmin()) return;
  var notifs = [];
  try{ notifs = JSON.parse(localStorage.getItem(NOTIF_KEY))||[]; }catch(e){}
  var unread = notifs.filter(function(n){
    return n.targetUserId === s.id && !n.read && new Date(n.createdAt).getTime() > _lastNotifCheck - 10000;
  });
  unread.forEach(function(n){
    if(!n._shown){ n._shown=true; showInAppNotif(n.addr, n.assignedByName||'관리자'); }
  });
  // 전체 미읽 카운트
  var allUnread = notifs.filter(function(n){ return n.targetUserId === s.id && !n.read; }).length;
  updateNotifBadge(allUnread);
}

function pushNotif(targetUserId, targetUserName, caseId, addr, insurer){
  var notifs = [];
  try{ notifs = JSON.parse(localStorage.getItem(NOTIF_KEY))||[]; }catch(e){}
  var n = {
    id: Date.now(),
    targetUserId: targetUserId,
    targetUserName: targetUserName,
    caseId: caseId,
    addr: addr,
    insurer: insurer,
    assignedByName: '총괄관리자',
    createdAt: new Date().toISOString(),
    read: false
  };
  notifs.push(n);
  // 최대 100개 유지
  if(notifs.length > 100) notifs = notifs.slice(-100);
  localStorage.setItem(NOTIF_KEY, JSON.stringify(notifs));
  // BroadcastChannel으로 즉시 전파
  if(_notifBC) _notifBC.postMessage({ type:'NEW_ASSIGN', targetUserId:targetUserId, addr:addr, insurer:insurer, assignedByName:'총괄관리자' });
}

function markNotifsRead(){
  var s = getSession(); if(!s) return;
  var notifs = [];
  try{ notifs = JSON.parse(localStorage.getItem(NOTIF_KEY))||[]; }catch(e){}
  notifs.forEach(function(n){ if(n.targetUserId===s.id) n.read=true; });
  localStorage.setItem(NOTIF_KEY, JSON.stringify(notifs));
  updateNotifBadge(0);
}

function showInAppNotif(addr, byName){
  // 브라우저 네이티브 알림
  if('Notification' in window && Notification.permission === 'granted'){
    try{
      new Notification('📤 새 사건 배당 — Refound', {
        body: byName + '님이 배당했습니다\n' + addr,
        icon: 'https://cdn.imweb.me/thumbnail/20260410/1393b9649ac2d.png',
        tag: 'rfAssign'
      });
    }catch(e){}
  }
  // 인앱 팝업 슬라이드다운
  var popup = document.getElementById('notifPopup');
  var title = document.getElementById('notifTitle');
  var msg   = document.getElementById('notifMsg');
  if(popup && title && msg){
    title.textContent = '📤 새 사건이 배당되었습니다';
    msg.textContent   = byName + '님 배당 · ' + addr;
    popup.classList.add('show');
    setTimeout(function(){ popup.classList.remove('show'); }, 6000);
  }
  _lastNotifCheck = Date.now();
}

function closeNotifPopup(){
  var popup = document.getElementById('notifPopup');
  if(popup) popup.classList.remove('show');
