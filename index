function getMyAllCases(){
  // getSaves() 는 이미 로그인 사용자 키 기반
  return Object.values(getSaves());
}
function renderMyStats(){
  var cases = getMyAllCases();
  var active=0, done=0, overdue=0;
  cases.forEach(function(c){
    var st=myGetStatus(c);
    if(MY_STATUS_DONE.indexOf(st)<0){ active++; if(myDaysDiff(c.basic&&c.basic.accDate)>30) overdue++; }
    else done++;
  });
  var html = '<div class="my-sbox" style="background:var(--blueL)"><div class="msl">전체</div><div class="msv" style="color:var(--blue)">'+cases.length+'</div></div>'
    +'<div class="my-sbox" style="background:var(--redL)"><div class="msl">진행중</div><div class="msv" style="color:var(--red)">'+active+'</div></div>'
    +'<div class="my-sbox" style="background:var(--greenL)"><div class="msl">완결</div><div class="msv" style="color:var(--green)">'+done+'</div></div>';
  if(overdue) html += '<div class="my-sbox" style="background:var(--goldL);grid-column:1/-1"><div class="msl">⚠️ 30일 초과 미결</div><div class="msv" style="color:var(--gold)">'+overdue+'건</div></div>';

  // 관리자: 담당자별 미결 현황 추가
  if(isAdmin()){
    var staffMap = {};
    cases.forEach(function(c){
      var st = myGetStatus(c);
      if(MY_STATUS_DONE.indexOf(st) >= 0) return;
      var nm = (c.basic&&c.basic.userName) || (c.basic&&c.basic.staff) || '미배정';
      staffMap[nm] = (staffMap[nm]||0)+1;
    });
    var staffArr = Object.entries(staffMap).sort(function(a,b){return b[1]-a[1];});
    if(staffArr.length){
      html += '<div style="grid-column:1/-1;background:var(--bg2);border:1px solid var(--rule);border-radius:10px;padding:11px 13px">'
        +'<div style="font-size:10px;font-weight:700;color:var(--ink3);margin-bottom:8px;letter-spacing:1px">담당자별 미결</div>'
        + staffArr.map(function(e){
            return '<div style="display:flex;justify-content:space-between;font-size:12px;padding:3px 0;border-bottom:1px solid var(--rule)">'
              +'<span style="font-weight:600">'+e[0]+'</span>'
              +'<span style="color:var(--red);font-weight:700">'+e[1]+'건</span>'
              +'</div>';
          }).join('')
        +'</div>';
    }
  }
  document.getElementById('myStats').innerHTML = html;
}
function buildMyChips(){
  // 상태 필터
  var chips=[{l:'전체',v:''}].concat(MY_STATUS_LIST.map(function(s){return{l:s,v:s};}));
  var html = '<div style="display:flex;gap:5px;flex-wrap:wrap;margin-bottom:6px">'
    + chips.map(function(c){
        return '<div class="my-chip'+(myFilterStatus===c.v?' on':'')+'" onclick="mySetFilter(\''+c.v+'\')">' +c.l+'</div>';
      }).join('')
    + '</div>';

  // 관리자: 담당자 필터 추가
  if(isAdmin()){
    var allCases = Object.values(getSaves());
    var staffSet = {};
    allCases.forEach(function(c){ var nm=(c.basic&&c.basic.userName)||(c.basic&&c.basic.staff); if(nm) staffSet[nm]=true; });
    var staffNames = Object.keys(staffSet).sort();
    if(staffNames.length){
      html += '<div style="display:flex;gap:5px;flex-wrap:wrap">'
        + '<div class="my-chip'+(myFilterStaff===''?' on':'')+'" onclick="mySetStaffFilter(\'\')" style="border-color:var(--gold);'+(myFilterStaff===''?'background:var(--gold);color:#fff;':'')+'">'
        + '👥 전체 담당자</div>'
        + staffNames.map(function(nm){
            return '<div class="my-chip'+(myFilterStaff===nm?' on':'')+'" onclick="mySetStaffFilter(\''+nm+'\')" style="border-color:var(--gold);'+(myFilterStaff===nm?'background:var(--gold);color:#fff;':'')+'">'
              + nm + '</div>';
          }).join('')
        + '</div>';
    }
  }
  document.getElementById('myChips').innerHTML = html;
}
function mySetFilter(v){ myFilterStatus=v; buildMyChips(); renderMyCases(); }
function mySetStaffFilter(v){ myFilterStaff=v; buildMyChips(); renderMyCases(); }
function renderMyCases(){
  var cases = getMyAllCases();
  if(myFilterStatus) cases = cases.filter(function(c){ return myGetStatus(c)===myFilterStatus; });
  if(isAdmin() && myFilterStaff){
    cases = cases.filter(function(c){
      var nm = (c.basic&&c.basic.userName)||(c.basic&&c.basic.staff)||'';
      return nm === myFilterStaff;
    });
  }
  cases.sort(function(a,b){
    var da=(a.basic&&a.basic.accDate)||a.savedAt||'';
    var db=(b.basic&&b.basic.accDate)||b.savedAt||'';
    return db>da?1:-1;
  });
  document.getElementById('myCaseCount').textContent = cases.length;
  if(!cases.length){
    document.getElementById('myCaseList').innerHTML='<div class="my-empty"><div class="ei">📭</div>사건이 없습니다<br><small style="font-size:11px;margin-top:4px;display:block">기본정보 탭에서 작성 후 저장하면 여기에 표시됩니다</small></div>';
    return;
  }
  document.getElementById('myCaseList').innerHTML = cases.map(function(c){
    var st=myGetStatus(c), sc=MY_SC[st]||MY_SC['접수'], bc=MY_BORDER[st]||'#e0dbd4';
    var b=c.basic||{}, addr=b.address||c.title||c.caseId||'-';
    var ins=myGetInsurer(c), amt=myCalcGrand(c), days=myDaysDiff(b.accDate);
    var overdue=days>30 && MY_STATUS_DONE.indexOf(st)<0;
    var adm=getAdminData(), amemo=(adm[c.caseId]&&adm[c.caseId].memo)||'';
    var staffName = b.userName||b.staff||'';
    return '<div class="my-case-card" style="border-left-color:'+bc+'" onclick="myOpenDetail(\''+c.caseId+'\')">'
      +'<div class="mcr1"><div class="mc-title">'+(overdue?'⚠️ ':'')+addr+'</div>'
      +'<span class="mc-stag" style="background:'+sc.bg+';color:'+sc.c+'">'+st+'</span></div>'
      +'<div class="mcr2">'
      +'<span>'+ins+'</span>'
      +(b.accDate?'<span>'+b.accDate+'</span>':'')
      +(isAdmin()&&staffName?'<span style="background:var(--navy);color:#fff;padding:1px 7px;border-radius:20px;font-size:10px;font-weight:700">👤 '+staffName+'</span>':'')
      +(amt?'<span style="color:var(--blue);font-weight:700">'+myFmt(amt)+'</span>':'')
      +(overdue?'<span style="color:var(--red);font-weight:700">'+days+'일 경과</span>':'')
      +(amemo?'<span>📝 '+amemo.slice(0,20)+(amemo.length>20?'…':'')+'</span>':'')
      +'</div></div>';
  }).join('');
}

// ── 내 사건 상세 모달 ──
function myOpenDetail(caseId){
  var saves=getSaves(), adm=getAdminData();
  var c=saves[caseId]; if(!c){showToast('데이터 없음');return;}
  myCurCaseId=caseId;
  var b=c.basic||{}, cadm=adm[caseId]||{};
  var st=myGetStatus(c); myCurStatus=st;
  var grand=myCalcGrand(c);
  document.getElementById('mdTitle').textContent=b.address||c.title||caseId;
  document.getElementById('mdMeta').textContent=caseId+(c.savedAt?' | '+new Date(c.savedAt).toLocaleString('ko-KR'):'');
  document.getElementById('mdAmt').textContent=grand>0?myFmt(grand):'미계산';
  document.getElementById('mdInsurer').textContent=myGetInsurer(c);
  document.getElementById('mdDate').textContent=b.accDate||'-';
  document.getElementById('mdMemo').value=cadm.memo||'';
  document.getElementById('mdStatusGrid').innerHTML=MY_STATUS_LIST.map(function(s){
    var sc=MY_SC[s]||MY_SC['접수'],isOn=s===st;
    return '<button class="mst-btn'+(isOn?' active':'')+'" data-mst="'+s+'" onclick="mySetStatus(\''+s+'\')" style="'+(isOn?'background:'+sc.bg+';color:'+sc.c+';border-color:'+sc.c+';':'')+'">'+(isOn?'✓ ':'')+s+'</button>';
  }).join('');
  var hist=cadm.history||[];
  document.getElementById('mdHist').innerHTML=hist.length
    ?hist.slice().reverse().map(function(h){return'<div class="hist-item"><span style="color:var(--ink3)">'+h.date+'</span> → <b>'+h.status+'</b>'+(h.memo?' — <span style="color:var(--ink3)">'+h.memo+'</span>':'')+'</div>';}).join('')
    :'<div style="color:var(--ink3);font-size:12px;padding:6px 0">이력 없음</div>';
  openM('mMyDetail');
}
function mySetStatus(s){
  myCurStatus=s;
  document.querySelectorAll('.mst-btn').forEach(function(b){
    var bs=MY_SC[b.dataset.mst]||MY_SC['접수'],isOn=b.dataset.mst===s;
    b.classList.toggle('active',isOn);
    b.style.background=isOn?bs.bg:'';b.style.color=isOn?bs.c:'';b.style.borderColor=isOn?bs.c:'';
    b.textContent=(isOn?'✓ ':'')+b.dataset.mst;
  });
}
function mySaveStatus(){
  if(!myCurCaseId) return;
  var adm=getAdminData(), cadm=adm[myCurCaseId]||{};
  var memo=document.getElementById('mdMemo').value, now=new Date().toLocaleString('ko-KR');
  var hist=cadm.history||[];
  if(myCurStatus!==cadm.status||memo!==cadm.memo) hist.push({date:now,status:myCurStatus,memo:memo});
  cadm.status=myCurStatus;cadm.memo=memo;cadm.history=hist;
  adm[myCurCaseId]=cadm;setAdminData(adm);
  closeM('mMyDetail');showToast('✅ 상태 저장 완료');
  renderMyContent();
}
function myOpenInForm(){
  closeM('mMyDetail');loadCase(myCurCaseId);showTab('info');showToast('📂 사건을 불러왔습니다');
}
